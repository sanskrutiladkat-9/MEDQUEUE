  "meta": {
    "version": "1.0",
    "description": "Simulated hospital queue data for MedQueue prediction system",
    "dataType": "simulated",
    "lastUpdated": "2026-04-09",
    "updateFrequency": "Every 2 minutes in a live system"
  },

  "config": {
    "timeMultipliers": {
      "description": "Adjusts wait time based on time of day. Values above 1.0 mean busier than average.",
      "slots": {
        "early_morning": { "label": "Early Morning (6–8)",  "hours": [6,7],            "multiplier": 0.45 },
        "morning":       { "label": "Morning (8–12)",       "hours": [8,9,10,11],      "multiplier": 0.85 },
        "midday":        { "label": "Midday (12–14)",       "hours": [12,13],          "multiplier": 1.35 },
        "afternoon":     { "label": "Afternoon (14–17)",    "hours": [14,15,16],       "multiplier": 1.20 },
        "evening":       { "label": "Evening (17–20)",      "hours": [17,18,19],       "multiplier": 1.10 },
        "night":         { "label": "Night (20–24)",        "hours": [20,21,22,23],    "multiplier": 0.65 }
      }
    },

    "visitTypeModifiers": {
      "description": "Adjusts wait time based on patient visit category.",
      "types": {
        "standard":  { "label": "Standard Visit",           "multiplier": 1.00, "description": "Normal queue priority" },
        "urgent":    { "label": "Urgent (non-emergency)",   "multiplier": 0.60, "description": "Faster triage routing" },
        "followup":  { "label": "Follow-up Appointment",   "multiplier": 0.75, "description": "Pre-scheduled priority" },
        "emergency": { "label": "Emergency",                "multiplier": 0.30, "description": "Immediate triage — bypasses queue" }
      }
    },

    "loadThresholds": {
      "description": "Occupancy % thresholds used to classify department load level.",
      "low":      { "max": 64,  "label": "Low",      "color": "green" },
      "moderate": { "max": 79,  "label": "Moderate", "color": "warn"  },
      "high":     { "max": 100, "label": "High",      "color": "danger" }
    },

    "waitThresholds": {
      "description": "Total wait time (minutes) thresholds used to classify wait level.",
      "low":      { "max": 29,  "label": "Low wait",  "color": "green" },
      "moderate": { "max": 59,  "label": "Moderate",  "color": "warn"  },
      "high":     { "max": 999, "label": "High load",  "color": "danger" }
    },

    "hourlyPeakProfile": {
      "description": "Relative patient volume by hour (0–23). 1.0 = average load. Used for dashboard chart.",
      "values": [0.30, 0.25, 0.20, 0.18, 0.20, 0.40, 0.70, 1.00, 1.30, 1.40, 1.30, 1.20,
                 1.35, 1.25, 1.15, 1.05, 1.10, 1.30, 1.20, 0.95, 0.75, 0.60, 0.50, 0.38]
    }
  },

